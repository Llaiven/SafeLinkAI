@model RegisterViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SafeLink AI – Registro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <style>
        body { background: linear-gradient(135deg,#1a1a2e,#16213e,#7b0000); min-height:100vh; }
        .card { border:none; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,.4); }
        .btn-danger { background:#7b0000; border-color:#7b0000; }
        .btn-danger:hover { background:#a00000; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-4">
    <div class="col-md-5 col-sm-11">
        <div class="card p-4">
            <div class="text-center mb-3">
                <i class="bi bi-shield-fill-check fs-1 text-danger"></i>
                <h3 class="fw-bold mt-1">Crear Cuenta</h3>
                <p class="text-muted small">SafeLink AI – Registro ciudadano</p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="FullName" class="form-control" placeholder="Nombre Completo" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="0987654321" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmar contraseña" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 py-2 fw-bold">
                    <i class="bi bi-person-plus me-2"></i> Registrarme
                </button>
            </form>

            <div class="text-center mt-3">
                <small>¿Ya tienes cuenta?</small>
                <a asp-action="Login" class="ms-2 text-danger fw-semibold">Iniciar sesión</a>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
