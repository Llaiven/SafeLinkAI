@model RegisterViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>SafeLink AI – Registro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="sl-login-bg">
    <div class="sl-login-card" style="max-width:480px;">
        <div class="text-center mb-4">
            <div class="sl-login-logo"><i class="bi bi-person-plus-fill"></i></div>
            <div class="sl-login-title mt-2">Crear Cuenta</div>
            <div class="sl-login-sub">Únete a SafeLink AI</div>
        </div>
        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" style="background:#fdf2f2;border:1px solid #f5c6c6;border-radius:8px;padding:10px 14px;margin-bottom:16px;color:#922b21;font-size:13px;"></div>
            <div class="sl-form-group">
                <label class="sl-label">Nombre Completo</label>
                <div class="sl-input-group"><span class="sl-input-icon"><i class="bi bi-person"></i></span>
                <input asp-for="FullName" class="sl-input" placeholder="Tu nombre completo"/></div>
                <span asp-validation-for="FullName" class="sl-field-error"></span>
            </div>
            <div class="sl-form-group">
                <label class="sl-label">Correo electrónico</label>
                <div class="sl-input-group"><span class="sl-input-icon"><i class="bi bi-envelope"></i></span>
                <input asp-for="Email" class="sl-input" placeholder="correo@ejemplo.com"/></div>
                <span asp-validation-for="Email" class="sl-field-error"></span>
            </div>
            <div class="sl-form-group">
                <label class="sl-label">Teléfono <span style="color:#9ca3af;font-weight:400;">(opcional)</span></label>
                <div class="sl-input-group"><span class="sl-input-icon"><i class="bi bi-telephone"></i></span>
                <input asp-for="PhoneNumber" class="sl-input" placeholder="0987654321"/></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="sl-form-group">
                    <label class="sl-label">Contraseña</label>
                    <input asp-for="Password" class="sl-input" placeholder="Mínimo 6 caracteres"/>
                    <span asp-validation-for="Password" class="sl-field-error"></span>
                </div>
                <div class="sl-form-group">
                    <label class="sl-label">Confirmar</label>
                    <input asp-for="ConfirmPassword" class="sl-input" placeholder="Repetir contraseña"/>
                    <span asp-validation-for="ConfirmPassword" class="sl-field-error"></span>
                </div>
            </div>
            <button type="submit" class="sl-btn sl-btn-primary" style="width:100%;justify-content:center;padding:12px;font-size:15px;">
                <i class="bi bi-person-check"></i> Registrarme
            </button>
        </form>
        <div style="text-align:center;margin-top:16px;font-size:13px;color:#6c757d;">
            ¿Ya tienes cuenta? <a asp-action="Login" style="color:#c0392b;font-weight:600;">Iniciar sesión</a>
        </div>
    </div>
</div>
</body>
</html>
