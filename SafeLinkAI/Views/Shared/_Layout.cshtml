<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – SafeLink AI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="sl-wrapper">
        <!-- SIDEBAR -->
        <aside class="sl-sidebar">
            <div class="sl-brand">
                <div class="sl-brand-icon"><i class="bi bi-shield-fill-check"></i></div>
                <div>
                    <div class="sl-brand-name">SafeLink AI</div>
                    <div class="sl-brand-sub">Emergency Platform</div>
                </div>
            </div>

            <div class="sl-nav-section">
                <div class="sl-nav-label">PRINCIPAL</div>
                <a class="sl-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <span class="sl-nav-icon"><i class="bi bi-speedometer2"></i></span>
                    <span>Dashboard</span>
                </a>
                <a class="sl-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
                   asp-controller="Reports" asp-action="Index">
                    <span class="sl-nav-icon"><i class="bi bi-exclamation-triangle"></i></span>
                    <span>Reportes</span>
                    <span class="sl-nav-badge">!</span>
                </a>
                @if (User.IsInRole("Administrador"))
                {
                    <a class="sl-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                       asp-controller="Users" asp-action="Index">
                        <span class="sl-nav-icon"><i class="bi bi-people"></i></span>
                        <span>Usuarios</span>
                    </a>
                }
            </div>

            <div class="sl-nav-section">
                <div class="sl-nav-label">CUENTA</div>
                <a class="sl-nav-link" asp-controller="Home" asp-action="Notifications">
                    <span class="sl-nav-icon"><i class="bi bi-bell"></i></span>
                    <span>Notificaciones</span>
                </a>
            </div>

            <div class="sl-sidebar-footer">
                <div class="sl-user-chip">
                    <div class="sl-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "U")</div>
                    <div class="sl-user-info">
                        <div class="sl-user-name">@User.Identity?.Name?.Split('@')[0]</div>
                        <div class="sl-user-role">@(User.IsInRole("Administrador") ? "Administrador" : "Ciudadano")</div>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sl-logout-btn">
                        <i class="bi bi-box-arrow-left me-2"></i> Cerrar sesión
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="sl-content">
            <!-- Topbar -->
            <header class="sl-topbar">
                <div class="sl-topbar-title">
                    <span class="sl-page-title">@ViewData["Title"]</span>
                </div>
                <div class="sl-topbar-actions">
                    <a asp-controller="Reports" asp-action="Create" class="sl-btn-new">
                        <i class="bi bi-plus-lg me-1"></i> Nuevo Reporte
                    </a>
                </div>
            </header>

            <!-- Alerts -->
            <div class="sl-alerts-wrapper">
                @if (TempData["Success"] != null)
                {
                    <div class="sl-alert sl-alert-success">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        <button type="button" class="sl-alert-close" onclick="this.parentElement.remove()">×</button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="sl-alert sl-alert-danger">
                        <i class="bi bi-x-circle-fill me-2"></i> @TempData["Error"]
                        <button type="button" class="sl-alert-close" onclick="this.parentElement.remove()">×</button>
                    </div>
                }
            </div>

            <main class="sl-main">
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
