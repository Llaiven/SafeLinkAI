<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SafeLink AI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- SIDEBAR -->
    <div class="d-flex" id="wrapper">
        <div id="sidebar" class="bg-dark text-white d-flex flex-column p-3" style="min-height:100vh;width:230px;min-width:230px;">
            <a class="navbar-brand text-white fw-bold mb-4 d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shield-fill-check text-danger fs-4"></i>
                <span>SafeLink AI</span>
            </a>
            <ul class="nav flex-column gap-1 flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active bg-danger rounded" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active bg-danger rounded" : "")"
                       asp-controller="Reports" asp-action="Index">
                        <i class="bi bi-exclamation-triangle me-2"></i> Reportes
                    </a>
                </li>
                @if (User.IsInRole("Administrador"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active bg-danger rounded" : "")"
                           asp-controller="Users" asp-action="Index">
                            <i class="bi bi-people me-2"></i> Usuarios
                        </a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Home" asp-action="Notifications">
                        <i class="bi bi-bell me-2"></i> Notificaciones
                    </a>
                </li>
            </ul>
            <hr class="border-secondary" />
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-light btn-sm w-100">
                    <i class="bi bi-box-arrow-left me-1"></i> Cerrar Sesión
                </button>
            </form>
            <small class="text-secondary mt-2 text-center">@User.Identity?.Name</small>
        </div>

        <!-- CONTENT -->
        <div class="flex-grow-1 d-flex flex-column">
            <!-- Top bar -->
            <nav class="navbar navbar-light bg-white border-bottom px-4 py-2">
                <span class="navbar-text fw-semibold text-dark">@ViewData["Title"]</span>
                <span class="badge bg-danger">
                    <i class="bi bi-person-circle me-1"></i>
                    @(User.IsInRole("Administrador") ? "Administrador" : "Ciudadano")
                </span>
            </nav>

            <main class="flex-grow-1 p-4 bg-light">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-x-circle me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
