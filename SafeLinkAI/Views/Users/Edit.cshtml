@model SafeLinkAI.ViewModels.EditUserViewModel
@{ ViewData["Title"] = "Editar Usuario"; }

<div class="sl-card" style="max-width:560px;">
    <div class="sl-card-header"><span><i class="bi bi-person-gear" style="color:#c0392b;"></i> Editar Usuario</span></div>
    <div class="sl-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden"/>
            <div asp-validation-summary="All" style="background:#fdf2f2;border:1px solid #f5c6c6;border-radius:8px;padding:10px 14px;margin-bottom:16px;color:#922b21;font-size:13px;"></div>

            <div class="sl-form-group">
                <label class="sl-label">Nombre Completo</label>
                <input asp-for="FullName" class="sl-input"/>
                <span asp-validation-for="FullName" class="sl-field-error"></span>
            </div>
            <div class="sl-form-group">
                <label class="sl-label">Correo electrónico</label>
                <input asp-for="Email" class="sl-input"/>
                <span asp-validation-for="Email" class="sl-field-error"></span>
            </div>
            <div class="sl-form-group">
                <label class="sl-label">Teléfono</label>
                <input asp-for="PhoneNumber" class="sl-input"/>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="sl-form-group">
                    <label class="sl-label">Rol</label>
                    <select asp-for="Role" class="sl-select">
                        <option value="Ciudadano">Ciudadano</option>
                        <option value="Administrador">Administrador</option>
                    </select>
                </div>
                <div class="sl-form-group" style="display:flex;align-items:flex-end;padding-bottom:18px;">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;">
                        <input asp-for="IsActive" type="checkbox" style="width:16px;height:16px;accent-color:#27ae60;"/>
                        Usuario Activo
                    </label>
                </div>
            </div>
            <div style="display:flex;gap:8px;">
                <button type="submit" class="sl-btn sl-btn-primary"><i class="bi bi-save-fill"></i> Guardar</button>
                <a asp-action="Index" class="sl-btn sl-btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
