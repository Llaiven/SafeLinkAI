@model List<SafeLinkAI.Models.ApplicationUser>
@{ ViewData["Title"] = "Gestión de Usuarios"; }

<form method="get" class="d-flex gap-2 mb-4" style="max-width:400px;">
    <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Buscar por nombre o correo..." />
    <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-search"></i></button>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x"></i></a>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom d-flex justify-content-between">
        <span class="fw-bold"><i class="bi bi-people me-2 text-danger"></i>Usuarios (@Model.Count)</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Registro</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr class="@(user.IsActive ? "" : "table-secondary text-muted")">
                        <td class="fw-semibold">@user.FullName</td>
                        <td class="small">@user.Email</td>
                        <td>
                            <span class="badge @(user.Role == "Administrador" ? "bg-danger" : "bg-primary")">
                                @user.Role
                            </span>
                        </td>
                        <td>
                            <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                @(user.IsActive ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="small text-muted">@user.CreatedAt.ToString("dd/MM/yy")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-secondary btn-sm" title="Detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(user.IsActive ? "Desactivar" : "Activar")">
                                        <i class="bi bi-@(user.IsActive ? "pause" : "play")"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post"
                                      onsubmit="return confirm('¿Eliminar usuario @user.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
