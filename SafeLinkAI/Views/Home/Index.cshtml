@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="sl-stat-grid">
    <div class="sl-stat-card red">
        <div class="sl-stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div><div class="sl-stat-value">@Model.TotalReports</div><div class="sl-stat-label">Total Reportes</div></div>
    </div>
    <div class="sl-stat-card orange">
        <div class="sl-stat-icon"><i class="bi bi-fire"></i></div>
        <div><div class="sl-stat-value">@Model.ActiveReports</div><div class="sl-stat-label">Activos</div></div>
    </div>
    <div class="sl-stat-card blue">
        <div class="sl-stat-icon"><i class="bi bi-clock-history"></i></div>
        <div><div class="sl-stat-value">@Model.AttendingReports</div><div class="sl-stat-label">En Atención</div></div>
    </div>
    <div class="sl-stat-card green">
        <div class="sl-stat-icon"><i class="bi bi-check-circle-fill"></i></div>
        <div><div class="sl-stat-value">@Model.ResolvedReports</div><div class="sl-stat-label">Resueltos</div></div>
    </div>
    @if (User.IsInRole("Administrador"))
    {
        <div class="sl-stat-card purple">
            <div class="sl-stat-icon"><i class="bi bi-people-fill"></i></div>
            <div><div class="sl-stat-value">@Model.TotalUsers</div><div class="sl-stat-label">Usuarios</div></div>
        </div>
    }
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <!-- Quick actions -->
    <div class="sl-card">
        <div class="sl-card-header"><span><i class="bi bi-lightning-charge" style="color:#c0392b;"></i> Acciones Rápidas</span></div>
        <div class="sl-card-body" style="display:flex;flex-direction:column;gap:12px;">
            <a asp-controller="Reports" asp-action="Create" class="sl-btn sl-btn-primary">
                <i class="bi bi-plus-circle"></i> Reportar Emergencia
            </a>
            <a asp-controller="Reports" asp-action="Index" class="sl-btn sl-btn-secondary">
                <i class="bi bi-list-ul"></i> Ver Todos los Reportes
            </a>
            <a asp-controller="Home" asp-action="Notifications" class="sl-btn sl-btn-outline">
                <i class="bi bi-bell"></i> Notificaciones
                @if (Model.UnreadNotifications > 0)
                {
                    <span style="background:#c0392b;color:#fff;border-radius:10px;padding:1px 7px;font-size:11px;margin-left:4px;">@Model.UnreadNotifications</span>
                }
            </a>
        </div>
    </div>

    <!-- Status summary -->
    <div class="sl-card">
        <div class="sl-card-header"><span><i class="bi bi-bar-chart-fill" style="color:#c0392b;"></i> Estado de Incidentes</span></div>
        <div class="sl-card-body">
            @{
                var total = Model.TotalReports > 0 ? Model.TotalReports : 1;
                var pctActive   = (int)((double)Model.ActiveReports   / total * 100);
                var pctAttend   = (int)((double)Model.AttendingReports / total * 100);
                var pctResolved = (int)((double)Model.ResolvedReports  / total * 100);
            }
            <div style="margin-bottom:14px;">
                <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;">
                    <span style="color:#c0392b;font-weight:600;"><i class="bi bi-circle-fill me-1" style="font-size:8px;"></i>Activos</span>
                    <span>@Model.ActiveReports</span>
                </div>
                <div style="background:#f0f2f5;border-radius:99px;height:8px;overflow:hidden;">
                    <div style="background:#c0392b;height:100%;width:@(pctActive)%;border-radius:99px;transition:width .5s;"></div>
                </div>
            </div>
            <div style="margin-bottom:14px;">
                <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;">
                    <span style="color:#e67e22;font-weight:600;"><i class="bi bi-circle-fill me-1" style="font-size:8px;"></i>En Atención</span>
                    <span>@Model.AttendingReports</span>
                </div>
                <div style="background:#f0f2f5;border-radius:99px;height:8px;overflow:hidden;">
                    <div style="background:#e67e22;height:100%;width:@(pctAttend)%;border-radius:99px;transition:width .5s;"></div>
                </div>
            </div>
            <div>
                <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;">
                    <span style="color:#27ae60;font-weight:600;"><i class="bi bi-circle-fill me-1" style="font-size:8px;"></i>Resueltos</span>
                    <span>@Model.ResolvedReports</span>
                </div>
                <div style="background:#f0f2f5;border-radius:99px;height:8px;overflow:hidden;">
                    <div style="background:#27ae60;height:100%;width:@(pctResolved)%;border-radius:99px;transition:width .5s;"></div>
                </div>
            </div>
        </div>
    </div>
</div>
