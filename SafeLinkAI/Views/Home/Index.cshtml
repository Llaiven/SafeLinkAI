@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="row g-4 mb-4">
    <!-- Card: Total Reportes -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #7b0000!important;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Total Reportes</div>
                    <div class="fs-2 fw-bold">@Model.TotalReports</div>
                </div>
                <i class="bi bi-exclamation-triangle fs-1 text-danger opacity-50"></i>
            </div>
        </div>
    </div>
    <!-- Card: Activos -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Reportes Activos</div>
                    <div class="fs-2 fw-bold text-danger">@Model.ActiveReports</div>
                </div>
                <i class="bi bi-fire fs-1 text-danger opacity-50"></i>
            </div>
        </div>
    </div>
    <!-- Card: Resueltos -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Resueltos</div>
                    <div class="fs-2 fw-bold text-success">@Model.ResolvedReports</div>
                </div>
                <i class="bi bi-check-circle fs-1 text-success opacity-50"></i>
            </div>
        </div>
    </div>
    <!-- Card: Notificaciones -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Notificaciones</div>
                    <div class="fs-2 fw-bold text-warning">@Model.UnreadNotifications</div>
                </div>
                <i class="bi bi-bell fs-1 text-warning opacity-50"></i>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Administrador"))
{
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Usuarios Registrados</div>
                        <div class="fs-2 fw-bold text-primary">@Model.TotalUsers</div>
                    </div>
                    <i class="bi bi-people fs-1 text-primary opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
}

<!-- Quick actions -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title fw-bold">
                    <i class="bi bi-plus-circle text-danger me-2"></i> Reportar Emergencia
                </h5>
                <p class="text-muted small">Registra un nuevo incidente para que las autoridades puedan atenderlo.</p>
                <a asp-controller="Reports" asp-action="Create" class="btn btn-danger btn-sm">
                    <i class="bi bi-plus me-1"></i> Nuevo Reporte
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title fw-bold">
                    <i class="bi bi-list-ul text-secondary me-2"></i> Ver Mis Reportes
                </h5>
                <p class="text-muted small">Consulta el estado de todos tus reportes de emergencia registrados.</p>
                <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-right me-1"></i> Ver Reportes
                </a>
            </div>
        </div>
    </div>
</div>
