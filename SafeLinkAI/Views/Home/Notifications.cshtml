@model List<SafeLinkAI.Models.Notification>
@{ ViewData["Title"] = "Notificaciones"; }

<div class="sl-card">
    <div class="sl-card-header">
        <span><i class="bi bi-bell-fill" style="color:#c0392b;"></i> Notificaciones (@Model.Count)</span>
    </div>
    @if (!Model.Any())
    {
        <div style="text-align:center;padding:48px;color:#9ca3af;">
            <i class="bi bi-bell-slash" style="font-size:40px;display:block;margin-bottom:12px;"></i>
            No tienes notificaciones.
        </div>
    }
    else
    {
        <div>
            @foreach (var n in Model)
            {
                <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid #f0f2f5;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="width:36px;height:36px;background:#fdf2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#c0392b;font-size:16px;flex-shrink:0;">
                            <i class="bi bi-info-circle-fill"></i>
                        </div>
                        <div>
                            <div style="font-size:13.5px;font-weight:500;">@n.Message</div>
                            <div style="font-size:11.5px;color:#9ca3af;margin-top:2px;">@n.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </div>
                    <form asp-action="DeleteNotification" asp-route-id="@n.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="sl-btn sl-btn-danger sl-btn-sm sl-btn-icon" title="Eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    }
</div>
