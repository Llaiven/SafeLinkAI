<!-- Filters -->
<form method="get" class="card border-0 shadow-sm mb-4 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Buscar</label>
            <input type="text" name="SearchTerm" value="@ViewBag.Filter?.SearchTerm" class="form-control form-control-sm" placeholder="Título o descripción..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Estado</label>
            <select name="StatusFilter" class="form-select form-select-sm">
                <option value="">Todos</option>
                @foreach (var s in Enum.GetValues<SafeLinkAI.Models.ReportStatus>())
                {
                    <option value="@s" selected="@(ViewBag.Filter?.StatusFilter == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Categoría</label>
            <select name="CategoryFilter" class="form-select form-select-sm">
