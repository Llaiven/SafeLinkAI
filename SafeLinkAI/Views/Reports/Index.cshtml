@model ReportsDashboardViewModel
@{ ViewData["Title"] = "Reportes de Emergencia"; }

<!-- Stats -->
<div class="sl-stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px;">
    <div class="sl-stat-card red">
        <div class="sl-stat-icon"><i class="bi bi-fire"></i></div>
        <div><div class="sl-stat-value">@Model.TotalActivos</div><div class="sl-stat-label">Activos</div></div>
    </div>
    <div class="sl-stat-card orange">
        <div class="sl-stat-icon"><i class="bi bi-clock-history"></i></div>
        <div><div class="sl-stat-value">@Model.TotalEnAtencion</div><div class="sl-stat-label">En Atención</div></div>
    </div>
    <div class="sl-stat-card green">
        <div class="sl-stat-icon"><i class="bi bi-check-circle-fill"></i></div>
        <div><div class="sl-stat-value">@Model.TotalResueltos</div><div class="sl-stat-label">Resueltos</div></div>
    </div>
</div>

<!-- Charts -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div class="sl-card">
        <div class="sl-card-header"><span><i class="bi bi-pie-chart-fill" style="color:#c0392b;"></i> Incidentes por Categoría</span></div>
        <div class="sl-card-body" style="display:flex;align-items:center;gap:24px;">
            <div style="flex:1;position:relative;height:180px;">
                <canvas id="categoryChart"></canvas>
            </div>
            <div class="sl-legend">
                @{ var catColors = new Dictionary<string,string>{{"Accidente","#c0392b"},{"Incendio","#e67e22"},{"Robo","#8e44ad"},{"Inundacion","#2980b9"},{"Otro","#7f8c8d"}}; }
                @foreach (var kv in Model.PorCategoria)
                {
                    var col = catColors.ContainsKey(kv.Key) ? catColors[kv.Key] : "#999";
                    <div class="sl-legend-item">
                        <div class="sl-legend-dot" style="background:@col;"></div>
                        <span style="flex:1;">@kv.Key</span>
                        <strong>@kv.Value</strong>
                    </div>
                }
                @if (!Model.PorCategoria.Any())
                { <div style="color:#9ca3af;font-size:12px;">Sin datos</div> }
            </div>
        </div>
    </div>

    <div class="sl-card">
        <div class="sl-card-header"><span><i class="bi bi-clock" style="color:#c0392b;"></i> Reportes Recientes</span></div>
        <div>
            @if (!Model.Recientes.Any())
            { <div style="text-align:center;padding:32px;color:#9ca3af;">Sin reportes recientes.</div> }
            @foreach (var r in Model.Recientes)
            {
                var dotColor = r.Status == ReportStatus.Activo ? "#c0392b" : r.Status == ReportStatus.EnAtencion ? "#e67e22" : "#27ae60";
                <div style="display:flex;align-items:center;gap:10px;padding:10px 20px;border-bottom:1px solid #f0f2f5;">
                    <div style="width:8px;height:8px;border-radius:50%;background:@dotColor;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@r.Title</div>
                        <div style="font-size:11px;color:#9ca3af;">@r.Category • @r.CreatedAt.ToString("dd/MM HH:mm")</div>
                    </div>
                    <a asp-action="Details" asp-route-id="@r.Id" style="color:#c0392b;font-size:13px;text-decoration:none;"><i class="bi bi-arrow-right"></i></a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Table -->
<div class="sl-card">
    <div class="sl-card-header">
        <span><i class="bi bi-table" style="color:#c0392b;"></i> Todos los Reportes (@Model.Reports.Count)</span>
        <a asp-action="Create" class="sl-btn sl-btn-primary sl-btn-sm"><i class="bi bi-plus-lg"></i> Nuevo</a>
    </div>

    <!-- Filters -->
    <div style="padding:16px 20px;border-bottom:1px solid #f0f2f5;background:#fafbfc;">
        <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
            <div style="flex:1;min-width:180px;">
                <label class="sl-label">Buscar</label>
                <div class="sl-input-group">
                    <span class="sl-input-icon"><i class="bi bi-search"></i></span>
                    <input type="text" name="SearchTerm" value="@Model.Filter.SearchTerm" class="sl-input" placeholder="Título o descripción..." style="padding-left:36px;"/>
                </div>
            </div>
            <div style="min-width:140px;">
                <label class="sl-label">Estado</label>
                <select name="StatusFilter" class="sl-select">
                    <option value="">Todos</option>
                    <option value="Activo"     selected="@(Model.Filter.StatusFilter == "Activo"     ? "selected" : null)">Activo</option>
                    <option value="EnAtencion" selected="@(Model.Filter.StatusFilter == "EnAtencion" ? "selected" : null)">En Atención</option>
                    <option value="Resuelto"   selected="@(Model.Filter.StatusFilter == "Resuelto"   ? "selected" : null)">Resuelto</option>
                </select>
            </div>
            <div style="min-width:140px;">
                <label class="sl-label">Categoría</label>
                <select name="CategoryFilter" class="sl-select">
                    <option value="">Todas</option>
                    <option value="Accidente"  selected="@(Model.Filter.CategoryFilter == "Accidente"  ? "selected" : null)">Accidente</option>
                    <option value="Incendio"   selected="@(Model.Filter.CategoryFilter == "Incendio"   ? "selected" : null)">Incendio</option>
                    <option value="Robo"       selected="@(Model.Filter.CategoryFilter == "Robo"       ? "selected" : null)">Robo</option>
                    <option value="Inundacion" selected="@(Model.Filter.CategoryFilter == "Inundacion" ? "selected" : null)">Inundación</option>
                    <option value="Otro"       selected="@(Model.Filter.CategoryFilter == "Otro"       ? "selected" : null)">Otro</option>
                </select>
            </div>
            <div style="display:flex;gap:8px;">
                <button type="submit" class="sl-btn sl-btn-primary">Filtrar</button>
                <a asp-action="Index" class="sl-btn sl-btn-secondary">Limpiar</a>
            </div>
        </form>
    </div>

    <div class="sl-table-wrap">
        <table class="sl-table">
            <thead>
                <tr><th>#</th><th>Título</th><th>Categoría</th><th>Estado</th><th>Reportado por</th><th>Fecha</th><th style="text-align:center;">Acciones</th></tr>
            </thead>
            <tbody>
                @if (!Model.Reports.Any())
                {
                    <tr><td colspan="7" style="text-align:center;padding:40px;color:#9ca3af;">
                        <i class="bi bi-inbox" style="font-size:32px;display:block;margin-bottom:8px;"></i>No se encontraron reportes.
                    </td></tr>
                }
                @foreach (var r in Model.Reports)
                {
                    var catBadge = r.Category switch { ReportCategory.Accidente => "sl-badge-red", ReportCategory.Incendio => "sl-badge-yellow", ReportCategory.Inundacion => "sl-badge-blue", _ => "sl-badge-gray" };
                    var stBadge  = r.Status  switch { ReportStatus.Activo => "sl-badge-red", ReportStatus.EnAtencion => "sl-badge-yellow", ReportStatus.Resuelto => "sl-badge-green", _ => "sl-badge-gray" };
                    <tr>
                        <td style="color:#9ca3af;font-size:12px;">#@r.Id</td>
                        <td style="font-weight:600;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@r.Title</td>
                        <td><span class="sl-badge @catBadge">@r.Category</span></td>
                        <td><span class="sl-badge @stBadge">@r.Status</span></td>
                        <td style="font-size:12.5px;color:#6c757d;">@(r.User?.FullName ?? "—")</td>
                        <td style="font-size:12px;color:#9ca3af;">@r.CreatedAt.ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            <div style="display:flex;gap:6px;justify-content:center;align-items:center;">
                                <a asp-action="Details" asp-route-id="@r.Id" class="sl-btn sl-btn-outline sl-btn-sm sl-btn-icon" title="Ver"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit"    asp-route-id="@r.Id" class="sl-btn sl-btn-outline sl-btn-sm sl-btn-icon" title="Editar"><i class="bi bi-pencil"></i></a>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <form asp-action="UpdateStatus" asp-route-id="@r.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <select name="status" onchange="this.form.submit()" class="sl-select" style="padding:4px 8px;font-size:12px;width:auto;">
                                            <option value="Activo"     selected="@(r.Status == ReportStatus.Activo     ? "selected" : null)">Activo</option>
                                            <option value="EnAtencion" selected="@(r.Status == ReportStatus.EnAtencion ? "selected" : null)">En Atención</option>
                                            <option value="Resuelto"   selected="@(r.Status == ReportStatus.Resuelto   ? "selected" : null)">Resuelto</option>
                                        </select>
                                    </form>
                                }
                                <form asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;" onsubmit="return confirm('¿Eliminar reporte #@r.Id?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="sl-btn sl-btn-danger sl-btn-sm sl-btn-icon" title="Eliminar"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const catData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PorCategoria));
const labels = Object.keys(catData);
const values = Object.values(catData);
const palette = ['#c0392b','#e67e22','#8e44ad','#2980b9','#7f8c8d'];
if (labels.length > 0) {
    new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: { labels, datasets: [{ data: values, backgroundColor: palette.slice(0, labels.length), borderWidth: 0, hoverOffset: 6 }] },
        options: { cutout: '70%', plugins: { legend: { display: false } }, responsive: true, maintainAspectRatio: false }
    });
}
</script>
}
