                @foreach (var c in Enum.GetValues<SafeLinkAI.Models.ReportCategory>())
                {
                    <option value="@c" selected="@(ViewBag.Filter?.CategoryFilter == c.ToString())">@c</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-danger btn-sm w-100">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                <i class="bi bi-x"></i>
            </a>
        </div>
    </div>
</form>

