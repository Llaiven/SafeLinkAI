@model List<SafeLinkAI.Models.EmergencyReport>
@{ ViewData["Title"] = "Reportes de Emergencia"; }

<!-- Filters -->
<form method="get" class="card border-0 shadow-sm mb-4 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Buscar</label>
            <input type="text" name="SearchTerm" value="@ViewBag.Filter?.SearchTerm" class="form-control form-control-sm" placeholder="Título o descripción..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Estado</label>
            <select name="StatusFilter" class="form-select form-select-sm">
                <option value="">Todos</option>
                @foreach (var s in Enum.GetValues<SafeLinkAI.Models.ReportStatus>())
                {
                    <option value="@s" selected="@(ViewBag.Filter?.StatusFilter == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Categoría</label>
            <select name="CategoryFilter" class="form-select form-select-sm">
                <option value="">Todas</option>
                @foreach (var c in Enum.GetValues<SafeLinkAI.Models.ReportCategory>())
                {
                    <option value="@c" selected="@(ViewBag.Filter?.CategoryFilter == c.ToString())">@c</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-danger btn-sm w-100">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                <i class="bi bi-x"></i>
            </a>
        </div>
    </div>
</form>

<!-- Action bar -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">@Model.Count reporte(s) encontrado(s)</span>
    <a asp-action="Create" class="btn btn-danger btn-sm">
        <i class="bi bi-plus-circle me-1"></i> Nuevo Reporte
    </a>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Título</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th>Reportado por</th>
                    <th>Fecha</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-3 d-block mb-2 opacity-50"></i>
                            No se encontraron reportes.
                        </td>
                    </tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="text-muted small">@r.Id</td>
                        <td class="fw-semibold">@r.Title</td>
                        <td>
                            <span class="badge bg-secondary">@r.Category</span>
                        </td>
                        <td>
                            @{
                                var badgeClass = r.Status switch
                                {
                                    SafeLinkAI.Models.ReportStatus.Activo => "bg-danger",
                                    SafeLinkAI.Models.ReportStatus.EnAtencion => "bg-warning text-dark",
                                    SafeLinkAI.Models.ReportStatus.Resuelto => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@r.Status</span>
                        </td>
                        <td class="small text-muted">@(r.User?.FullName ?? "—")</td>
                        <td class="small text-muted">@r.CreatedAt.ToString("dd/MM/yy HH:mm")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-outline-secondary btn-sm" title="Detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline-primary btn-sm" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <form asp-action="UpdateStatus" asp-route-id="@r.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <select name="status" onchange="this.form.submit()" class="form-select form-select-sm d-inline-block w-auto">
                                            @foreach (var s in Enum.GetValues<SafeLinkAI.Models.ReportStatus>())
                                            {
                                                <option value="@s" selected="@(r.Status == s)">@s</option>
                                            }
                                        </select>
                                    </form>
                                }
                                <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar este reporte?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
