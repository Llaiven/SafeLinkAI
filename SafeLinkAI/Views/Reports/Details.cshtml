@model SafeLinkAI.Models.EmergencyReport
@{ ViewData["Title"] = "Detalles del Reporte"; }

@if (Model.Latitude.HasValue && Model.Longitude.HasValue)
{
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">
    <!-- Info -->
    <div class="sl-card">
        <div class="sl-card-header">
            <span><i class="bi bi-file-text-fill" style="color:#c0392b;"></i> Reporte #@Model.Id</span>
            @{
                var stBadge = Model.Status switch {
                    ReportStatus.Activo     => "sl-badge-red",
                    ReportStatus.EnAtencion => "sl-badge-yellow",
                    ReportStatus.Resuelto   => "sl-badge-green",
                    _                       => "sl-badge-gray"
                };
            }
            <span class="sl-badge @stBadge">@Model.Status</span>
        </div>
        <div class="sl-card-body">
            <h3 style="font-size:18px;font-weight:800;margin-bottom:16px;">@Model.Title</h3>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                <div style="background:#f8f9fa;border-radius:8px;padding:12px;">
                    <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;">Categoría</div>
                    <div style="font-weight:700;margin-top:4px;">@Model.Category</div>
                </div>
                <div style="background:#f8f9fa;border-radius:8px;padding:12px;">
                    <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;">Reportado por</div>
                    <div style="font-weight:700;margin-top:4px;">@(Model.User?.FullName ?? "—")</div>
                </div>
                <div style="background:#f8f9fa;border-radius:8px;padding:12px;">
                    <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;">Fecha</div>
                    <div style="font-weight:700;margin-top:4px;">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                @if (Model.UpdatedAt.HasValue)
                {
                    <div style="background:#f8f9fa;border-radius:8px;padding:12px;">
                        <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;">Actualizado</div>
                        <div style="font-weight:700;margin-top:4px;">@Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }
            </div>

            <div style="margin-bottom:16px;">
                <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Descripción</div>
                <p style="font-size:14px;line-height:1.6;color:#374151;">@Model.Description</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.Address))
            {
                <div style="display:flex;align-items:center;gap:8px;background:#fdf2f2;border-radius:8px;padding:10px 14px;margin-bottom:16px;">
                    <i class="bi bi-geo-alt-fill" style="color:#c0392b;font-size:16px;"></i>
                    <span style="font-size:13.5px;">@Model.Address</span>
                </div>
            }

            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <a href="https://www.openstreetmap.org/?mlat=@Model.Latitude&mlon=@Model.Longitude&zoom=16"
                   target="_blank" class="sl-btn sl-btn-outline" style="margin-bottom:16px;">
                    <i class="bi bi-box-arrow-up-right"></i> Abrir en OpenStreetMap
                </a>
            }

            <div style="display:flex;gap:8px;margin-top:8px;">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="sl-btn sl-btn-primary">
                    <i class="bi bi-pencil"></i> Editar
                </a>
                <a asp-action="Index" class="sl-btn sl-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>
        </div>
    </div>

    <!-- Map -->
    <div class="sl-card">
        <div class="sl-card-header"><span><i class="bi bi-map-fill" style="color:#c0392b;"></i> Ubicación del Incidente</span></div>
        <div class="sl-card-body" style="padding:12px;">
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <div id="map"></div>
            }
            else
            {
                <div style="text-align:center;padding:48px;color:#9ca3af;">
                    <i class="bi bi-geo-alt" style="font-size:40px;display:block;margin-bottom:12px;"></i>
                    No se registró ubicación para este reporte.
                </div>
            }
        </div>
    </div>
</div>

@if (Model.Latitude.HasValue && Model.Longitude.HasValue)
{
    @section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    const lat = @(Model.Latitude?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture));
    const lng = @(Model.Longitude?.ToString("F6", System.Globalization.CultureInfo.InvariantCulture));

    const map = L.map('map').setView([lat, lng], 16);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19
    }).addTo(map);

    const redIcon = L.icon({
        iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-red.png',
        shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34], shadowSize: [41, 41]
    });

    const marker = L.marker([lat, lng], { icon: redIcon }).addTo(map);
    marker.bindPopup('<strong>@Html.Raw(Model.Title.Replace("'", "\\'"))</strong><br/>@Model.Category').openPopup();

    // Circle of impact
    L.circle([lat, lng], {
        color: '#c0392b', fillColor: '#c0392b',
        fillOpacity: 0.1, radius: 100, weight: 1.5
    }).addTo(map);
    </script>
    }
}
