@model SafeLinkAI.Models.EmergencyReport
@{ ViewData["Title"] = "Nuevo Reporte"; }

<div class="card border-0 shadow-sm" style="max-width:700px;">
    <div class="card-header bg-danger text-white fw-bold">
        <i class="bi bi-plus-circle me-2"></i> Crear Reporte de Emergencia
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control" placeholder="Ej: Accidente de tránsito en Av. Amazonas" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Category" class="form-label fw-semibold"></label>
                    <select asp-for="Category" class="form-select"
                            asp-items="Html.GetEnumSelectList<SafeLinkAI.Models.ReportCategory>()"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Address" class="form-label fw-semibold"></label>
                    <input asp-for="Address" class="form-control" placeholder="Ej: Av. Amazonas y Naciones Unidas" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="4"
                          placeholder="Describe el incidente con el mayor detalle posible..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Latitude" class="form-label fw-semibold">
                        Latitud <small class="text-muted">(opcional)</small>
                    </label>
                    <input asp-for="Latitude" class="form-control" placeholder="-0.2295" step="0.000001" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Longitude" class="form-label fw-semibold">
                        Longitud <small class="text-muted">(opcional)</small>
                    </label>
                    <input asp-for="Longitude" class="form-control" placeholder="-78.5243" step="0.000001" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-send me-2"></i> Enviar Reporte
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
