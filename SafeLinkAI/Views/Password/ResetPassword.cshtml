@model ResetPasswordViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>SafeLink AI – Nueva Contraseña</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="sl-login-bg">
    <div class="sl-login-card">
        <div class="text-center mb-4">
            <div class="sl-login-logo"><i class="bi bi-shield-lock-fill"></i></div>
            <div class="sl-login-title mt-2">Nueva Contraseña</div>
            <div class="sl-login-sub">Crea una contraseña segura para tu cuenta</div>
        </div>

        <!-- Correo identificado -->
        <div style="background:#f8f9fa;border-radius:8px;padding:10px 14px;margin-bottom:16px;display:flex;align-items:center;gap:8px;font-size:13px;">
            <i class="bi bi-person-circle" style="color:#c0392b;font-size:16px;"></i>
            <span style="color:#6c757d;">Cuenta:</span>
            <strong>@Model.Email</strong>
        </div>

        <form asp-action="ResetPassword" asp-controller="Password" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token"/>
            <input type="hidden" asp-for="Email"/>

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background:#fdf2f2;border:1px solid #f5c6c6;border-radius:8px;padding:10px 14px;margin-bottom:16px;color:#922b21;font-size:13px;">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="sl-form-group">
                <label class="sl-label">Nueva contraseña</label>
                <div class="sl-input-group">
                    <span class="sl-input-icon"><i class="bi bi-lock"></i></span>
                    <input asp-for="NewPassword" class="sl-input" placeholder="Mínimo 6 caracteres" id="newPass"/>
                </div>
                <span asp-validation-for="NewPassword" class="sl-field-error"></span>
            </div>

            <div class="sl-form-group">
                <label class="sl-label">Confirmar contraseña</label>
                <div class="sl-input-group">
                    <span class="sl-input-icon"><i class="bi bi-lock-fill"></i></span>
                    <input asp-for="ConfirmPassword" class="sl-input" placeholder="Repite la contraseña"/>
                </div>
                <span asp-validation-for="ConfirmPassword" class="sl-field-error"></span>
            </div>

            <!-- Indicador de fuerza -->
            <div style="margin-bottom:16px;">
                <div style="display:flex;gap:4px;margin-bottom:4px;">
                    <div id="str1" style="flex:1;height:4px;border-radius:99px;background:#e9ecef;transition:background .3s;"></div>
                    <div id="str2" style="flex:1;height:4px;border-radius:99px;background:#e9ecef;transition:background .3s;"></div>
                    <div id="str3" style="flex:1;height:4px;border-radius:99px;background:#e9ecef;transition:background .3s;"></div>
                    <div id="str4" style="flex:1;height:4px;border-radius:99px;background:#e9ecef;transition:background .3s;"></div>
                </div>
                <div id="strLabel" style="font-size:11px;color:#9ca3af;"></div>
            </div>

            <button type="submit" class="sl-btn sl-btn-primary" style="width:100%;justify-content:center;padding:12px;font-size:15px;">
                <i class="bi bi-check-circle-fill"></i> Cambiar Contraseña
            </button>
        </form>

        <div style="text-align:center;margin-top:16px;font-size:13px;">
            <a asp-action="Login" asp-controller="Account" style="color:#c0392b;font-weight:600;">
                <i class="bi bi-arrow-left me-1"></i> Volver al Login
            </a>
        </div>
    </div>
</div>

<script>
// Password strength indicator
document.getElementById('newPass').addEventListener('input', function () {
    const v = this.value;
    let score = 0;
    if (v.length >= 6)  score++;
    if (v.length >= 10) score++;
    if (/[A-Z]/.test(v) && /[0-9]/.test(v)) score++;
    if (/[^A-Za-z0-9]/.test(v)) score++;

    const colors = ['#e74c3c','#e67e22','#f1c40f','#27ae60'];
    const labels = ['Muy débil','Débil','Buena','Segura'];
    for (let i = 1; i <= 4; i++) {
        document.getElementById('str'+i).style.background = i <= score ? colors[score-1] : '#e9ecef';
    }
    document.getElementById('strLabel').textContent = score > 0 ? labels[score-1] : '';
    document.getElementById('strLabel').style.color  = score > 0 ? colors[score-1] : '#9ca3af';
});
</script>
</body>
</html>
