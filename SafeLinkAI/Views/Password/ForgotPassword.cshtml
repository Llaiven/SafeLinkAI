@model ForgotPasswordViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>SafeLink AI – Recuperar Contraseña</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="sl-login-bg">
    <div class="sl-login-card">
        <div class="text-center mb-4">
            <div class="sl-login-logo"><i class="bi bi-key-fill"></i></div>
            <div class="sl-login-title mt-2">Recuperar Contraseña</div>
            <div class="sl-login-sub">Ingresa tu correo y te generaremos un enlace de recuperación</div>
        </div>

        <form asp-action="ForgotPassword" asp-controller="Password" method="post">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background:#fdf2f2;border:1px solid #f5c6c6;border-radius:8px;padding:10px 14px;margin-bottom:16px;color:#922b21;font-size:13px;">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="sl-form-group">
                <label class="sl-label">Correo electrónico registrado</label>
                <div class="sl-input-group">
                    <span class="sl-input-icon"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="sl-input" placeholder="correo@ejemplo.com" autocomplete="email"/>
                </div>
                <span asp-validation-for="Email" class="sl-field-error"></span>
            </div>

            <button type="submit" class="sl-btn sl-btn-primary" style="width:100%;justify-content:center;padding:12px;font-size:15px;">
                <i class="bi bi-send-fill"></i> Enviar enlace de recuperación
            </button>
        </form>

        <div style="text-align:center;margin-top:20px;font-size:13px;color:#6c757d;">
            <a asp-action="Login" asp-controller="Account" style="color:#c0392b;font-weight:600;">
                <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
            </a>
        </div>
    </div>
</div>
</body>
</html>
